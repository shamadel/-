# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# ADMOB_APP_ID: Google AdMob App ID (Test ID: ca-app-pub-3940256099942544~3347511713)
ADMOB_APP_ID=ca-app-pub-3940256099942544~3347511713

# ADMOB_BANNER_AD_UNIT_ID: Google AdMob Banner Ad Unit ID (Test ID: ca-app-pub-3940256099942544/6300978111)
ADMOB_BANNER_AD_UNIT_ID=ca-app-pub-3940256099942544/6300978111
